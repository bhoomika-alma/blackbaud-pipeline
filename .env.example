# ─────────────────────────────────────────────────────────────────────────────
# Backend env (Supabase Edge Functions — Deno).
# Copy to `.env` (gitignored) and fill in. Never commit real secrets.
# These are read by the Edge Functions in /supabase/functions.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL. Find it in: Supabase Dashboard → Project Settings → API → Project URL.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Supabase service-role key (server-side only; full DB + Storage access). SECRET.
# Find it in: Supabase Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HubSpot private-app access token(s). SECRET.
# Create at: HubSpot → Settings → Integrations → Private Apps → (your app) → Auth.
#
# Two-environment setup (recommended for testing):
#   - HUBSPOT_READ_TOKEN  → PRODUCTION account: classification reads (lists, imports,
#       deal lookups). Read scopes: crm.lists.read, crm.objects.deals.read,
#       crm.objects.companies.read, crm.objects.contacts.read, crm.import.
#   - HUBSPOT_WRITE_TOKEN → SANDBOX account: create/update/associate (+ the import's
#       pre-create existence search). Scopes: crm.objects.deals (read+write),
#       crm.objects.companies (read+write), crm.objects.contacts (read+write).
# Single-environment setup: set only HUBSPOT_TOKEN (used for both read and write).
HUBSPOT_TOKEN=pat-na1-your-token
HUBSPOT_READ_TOKEN=
HUBSPOT_WRITE_TOKEN=

# Supabase Storage bucket that holds uploaded Blackbaud CSVs. Default: bb-uploads.
BB_UPLOADS_BUCKET=bb-uploads

# HubSpot pipeline IDs for the four Blackbaud pipelines. These are written onto
# NEW deals (the `pipeline` property), so they must be valid in the WRITE
# environment. In the two-token setup that's the SANDBOX — set these to the
# sandbox's pipeline IDs (the defaults below are PRODUCTION ids and will be
# rejected on create if the sandbox uses different ids).
# Find them at: HubSpot → Settings → Objects → Deals → Pipelines (ID is in the URL / API).
HUBSPOT_PIPELINE_HIGHERED=16363685
HUBSPOT_PIPELINE_K12=23038595
HUBSPOT_PIPELINE_CANADA=36496197
HUBSPOT_PIPELINE_ENGLAND=36528146

# HubSpot deal-list names used to classify rows (Phase C). Defaults match the
# real lists; override only if your portal names them differently.
#   - INTERNAL: deals already moved to internal pipelines  → INTERNAL (skip)
#   - PIPELINE: deals currently in a Blackbaud pipeline     → EXISTING (update)
BB_LIST_INTERNAL=BB Pipeline Deals moved to Internal Pipelines
BB_LIST_PIPELINE=BB Pipeline Deals
