# ─────────────────────────────────────────────────────────────────────────────
# Frontend env (Vite + React). Copy to `frontend/.env` (gitignored) and fill in.
# Only VITE_-prefixed vars are exposed to the browser, so NEVER put secrets here
# (no service-role key, no HubSpot token — those live in the backend .env only).
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (same value as backend SUPABASE_URL).
# Find it in: Supabase Dashboard → Project Settings → API → Project URL.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Supabase anon/public key — safe to expose to the browser (RLS-gated).
# Find it in: Supabase Dashboard → Project Settings → API → anon public.
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Storage bucket the UI uploads CSVs to (must match backend BB_UPLOADS_BUCKET). Default: bb-uploads.
VITE_BB_UPLOADS_BUCKET=bb-uploads

# Optional: base URL for Edge Functions. Defaults to `${VITE_SUPABASE_URL}/functions/v1` if unset.
VITE_FUNCTIONS_URL=
